<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true"
    tools:context=".CreateLoanActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nuevo prestamo"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            android:textColor="@color/app_text_primary"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/app_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="1dp"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cliente"
                    android:textColor="@color/app_text_primary"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/clientSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_spinner_field"
                    android:popupBackground="@color/app_card" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Moneda"
                    android:textColor="@color/app_text_primary"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/currencySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_spinner_field"
                    android:popupBackground="@color/app_card" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Frecuencia de pago"
                    android:textColor="@color/app_text_primary"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/frequencySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_spinner_field"
                    android:popupBackground="@color/app_card" />

                <EditText
                    android:id="@+id/principalAmountInput"
                    style="@style/Widget.AppPrestamos.Input"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:hint="Monto prestado"
                    android:inputType="numberDecimal" />

                <EditText
                    android:id="@+id/profitPercentInput"
                    style="@style/Widget.AppPrestamos.Input"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:hint="Porcentaje de ganancia"
                    android:inputType="numberDecimal" />

                <EditText
                    android:id="@+id/installmentCountInput"
                    style="@style/Widget.AppPrestamos.Input"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:hint="Cantidad de cuotas"
                    android:inputType="number" />

                <EditText
                    android:id="@+id/loanNotesInput"
                    style="@style/Widget.AppPrestamos.Input"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:layout_marginTop="10dp"
                    android:gravity="top"
                    android:hint="Notas"
                    android:inputType="textMultiLine" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveLoanButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:text="Guardar prestamo"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>
