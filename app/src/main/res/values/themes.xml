<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Appprestamos" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="colorPrimary">@color/app_primary</item>
        <item name="colorPrimaryDark">@color/app_primary_dark</item>
        <item name="colorSecondary">@color/app_accent</item>
    </style>

    <style name="Theme.Appprestamos" parent="Base.Theme.Appprestamos" />

    <style name="Widget.AppPrestamos.Input" parent="@android:style/Widget.EditText">
        <item name="android:backgroundTint">@color/app_primary</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="android:textColorHint">@color/app_input_hint</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>
</resources>